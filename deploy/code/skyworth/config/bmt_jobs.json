{
  "bmts": {
    "false_reject_namuh": {
      "enabled": true,
      "runner": {
        "uri": "skyworth/runners/skyworth_gcc_release/kardome_runner",
        "deps_prefix": "skyworth/runners/lib"
      },
      "template_uri": "skyworth/config/input_template.json",
      "paths": {
        "dataset_prefix": "skyworth/inputs/false_rejects",
        "outputs_prefix": "skyworth/outputs/false_rejects",
        "results_prefix": "skyworth/results/false_rejects",
        "logs_prefix": "skyworth/results/logs/false_rejects"
      },
      "runtime": {
        "num_source_test": 0,
        "runner_timeout_sec": 120,
        "enable_overrides": {
          "KWS_CONFIG.KWS_ENABLE": true,
          "BIOMETRICS_CONFIG.BIO_ENABLE": false
        },
        "cache": {
          "enabled": true,
          "root": "~/bmt_workspace/cache",
          "dataset_ttl_sec": 300
        }
      },
      "gate": {
        "comparison": "gte",
        "tolerance_abs": 0.25
      },
      "warning_policy": {
        "bootstrap_without_baseline": true
      },
      "demo": {
        "force_pass": false
      },
      "artifacts": {
        "upload_outputs": false,
        "upload_outputs_contexts": [
          "manual"
        ]
      },
      "parsing": {
        "keyword": "NAMUH",
        "counter_pattern": "Hi NAMUH counter = (\\d+)"
      }
    }
  }
}
