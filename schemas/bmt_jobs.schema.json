{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bmt-gcloud/schemas/bmt_jobs.schema.json",
  "title": "BMT jobs config",
  "description": "Per-project BMT definitions. Keys under bmts are BMT ids (UUIDs recommended). Gate and parsing are project-specific; the base does not interpret them.",
  "type": "object",
  "required": ["bmts"],
  "additionalProperties": true,
  "properties": {
    "bmts": {
      "type": "object",
      "description": "Map of BMT id (e.g. UUID) to BMT config.",
      "additionalProperties": { "$ref": "#/$defs/bmt_entry" },
      "minProperties": 1
    }
  },
  "$defs": {
    "bmt_entry": {
      "type": "object",
      "description": "Single BMT definition.",
      "required": ["enabled", "paths", "runner", "gate"],
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean", "description": "Whether this BMT is enabled." },
        "paths": { "$ref": "#/$defs/paths" },
        "runner": { "$ref": "#/$defs/runner" },
        "template_uri": { "type": "string", "description": "Path under code bucket to input template JSON." },
        "gate": { "$ref": "#/$defs/gate" },
        "runtime": { "$ref": "#/$defs/runtime" },
        "warning_policy": {
          "type": "object",
          "description": "E.g. bootstrap_without_baseline (project-specific).",
          "additionalProperties": true
        },
        "parsing": {
          "type": "object",
          "description": "Score extraction from runner output (project-specific).",
          "properties": {
            "score_key": { "type": "string", "description": "Key in file result for numeric score." },
            "counter_pattern": { "type": "string", "description": "Regex with one capture group for the number." },
            "score_pattern": { "type": "string" },
            "keyword": { "type": "string" }
          },
          "additionalProperties": true
        },
        "demo": { "type": "object", "additionalProperties": true },
        "artifacts": { "type": "object", "additionalProperties": true }
      }
    },
    "paths": {
      "type": "object",
      "required": ["dataset_prefix", "outputs_prefix", "results_prefix", "logs_prefix"],
      "additionalProperties": false,
      "properties": {
        "dataset_prefix": { "type": "string", "description": "GCS path segment for dataset (under runtime bucket)." },
        "outputs_prefix": { "type": "string" },
        "results_prefix": { "type": "string" },
        "logs_prefix": { "type": "string" }
      }
    },
    "runner": {
      "type": "object",
      "required": ["uri"],
      "additionalProperties": true,
      "properties": {
        "uri": { "type": "string", "description": "Path under runtime bucket to runner binary." },
        "deps_prefix": { "type": "string", "description": "Optional prefix for runner deps (e.g. libs)." }
      }
    },
    "gate": {
      "type": "object",
      "description": "Input to project manager only. All scoring/gate logic lives in code (_evaluate_gate); schema does not define comparison logic.",
      "additionalProperties": true,
      "properties": {
        "tolerance_abs": { "type": "number", "description": "Absolute tolerance (manager may use in code)." }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "num_source_test": { "type": "integer" },
        "enable_overrides": { "type": "object", "additionalProperties": true },
        "cache": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "root": { "type": "string" },
            "dataset_ttl_sec": { "type": "integer" }
          },
          "additionalProperties": true
        }
      }
    }
  }
}
