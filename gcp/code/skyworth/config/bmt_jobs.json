{
  "_gate_note": "gate is input to the project manager only. Pass/fail logic is in code (_evaluate_gate). This example uses comparison + tolerance_abs.",
  "bmts": {
    "skyworth_default": {
      "enabled": true,
      "runner": {
        "uri": "skyworth/runners/skyworth_gcc_release/kardome_runner",
        "deps_prefix": "skyworth/runners/lib"
      },
      "template_uri": "skyworth/config/input_template.json",
      "paths": {
        "dataset_prefix": "skyworth/inputs/default",
        "outputs_prefix": "skyworth/outputs/default",
        "results_prefix": "skyworth/results/default",
        "logs_prefix": "skyworth/results/logs/default"
      },
      "runtime": {
        "num_source_test": 0,
        "cache": { "enabled": true, "root": "./cache", "dataset_ttl_sec": 300 }
      },
      "gate": {
        "pass_when": "current >= baseline - tolerance_abs",
        "comparison": "gte",
        "tolerance_abs": 0.25
      },
      "warning_policy": { "bootstrap_without_baseline": true },
      "parsing": { "keyword": "NAMUH", "counter_pattern": "Hi NAMUH counter = (\\d+)" }
    }
  }
}
