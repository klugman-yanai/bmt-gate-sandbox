#!/bin/sh
# Mock runner for BMT/Cloud Run testing. Accepts same interface as kardome_runner:
#   mock_kardome_runner <config.json>
# Prints the NAMUH counter line so the manager can parse score; exits 0.
# Use with a staged BMT manifest that sets runner.uri = projects/sk/mock_kardome_runner.
set -e
# Config path in $1 (optional to read; we emit a fixed counter for testing)
_counter="${BMT_MOCK_COUNTER:-57}"
echo "Hi NAMUH counter = ${_counter}"
exit 0
