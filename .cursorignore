# =============================================================================
# SECTION 1: GLOBAL & LANGUAGE IGNORES (The "Hide" Layer)
# =============================================================================

# VCS, OS, and IDE Metadata
.git/
.hg/
.svn/
.DS_Store
Thumbs.db
*.swp
*~
*.bak
*.tmp
.claude/
.vscode/
.idea/

# General Build & Archive
build/
dist/
out/
bin/
obj/
**/*.zip
**/*.7z
**/*.tar.gz
**/*.tar

# Python / uv / Ruff / Pytest
**/.venv/
**/venv/
**/__pycache__/
**/.pytest_cache/
**/.ruff_cache/
**/.mypy_cache/
**/.ipynb_checkpoints/
**/.coverage
**/htmlcov/
**/*.egg-info/
**/*.egg
.python-version

# C / C++ (Compiled & Tooling)
**/*.o
**/*.obj
**/*.a
**/*.lib
**/*.so
**/*.so.*
**/*.dylib
**/*.dll
**/*.exe
**/*.pdb
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
.cmake/
_deps/

# Infrastructure & Secrets
.pulumi/
.terraform/
*-key.json
secrets/
.env
.env.*

# =============================================================================
# SECTION 2: AGGRESSIVE IGNORES (The "Noise" Layer)
# =============================================================================

# Audio Data (Massive 20GB+ files identified in audit)
**/*.wav
**/*.mp3
**/*.flac
**/*.m4a

# High-verbosity files
compile_commands.json
**/Pulumi.stack.json
**/branch-status-context.json
**/site/
**/_build/
.cursor/history/

# =============================================================================
# SECTION 3: PROJECT SPECIFIC IGNORES (bmt-gcloud)
# =============================================================================

data/
audio/
sk_runtime/
.bmt_runtime/
remote/sk/runners/lib/
*.log
*.sqlite
*.db

# =============================================================================
# SECTION 4: GENERAL WHITELIST (Always at the bottom)
# =============================================================================

!.env.example
!CLAUDE.md
!README.md
!Justfile
!Makefile
!pyproject.toml
!**/pyproject.toml
!uv.lock
!CMakeLists.txt
!CMakePresets.json

# =============================================================================
# SECTION 5: PROJECT SPECIFIC WHITELIST (bmt-gcloud)
# =============================================================================

# Strategy & Planning
!ROADMAP.md
!AGENTS.md
!docs/
!docs/plans/
!docs/plans/**

# Shared Libraries & Dependencies
!**/shared/dependencies/*.so*
# Specifically whitelist Kardome library (case-insensitive approach)
!**/lib[kK]ardome.so*
!data/sk/lib/
