# BMT GitHub repository variables — copy to .env and fill in values.
# Run:  bash .github/bmt/config/bootstrap_gh_vars.sh
# Or:   bash .github/bmt/config/bootstrap_gh_vars.sh --env-file .github/bmt/config/.env.dev
#
# Client (workflow/CI) only needs the six required vars below to trigger BMT and
# talk to GCP. Optional vars have built-in defaults; BMT_STATUS_CONTEXT is
# written into the run trigger payload and consumed by the VM for commit status
# and Check Run — set it only if you need a non-default or to match branch protection.
#
# Repo Actions config used by bootstrap:
#   Variable: BMT_DISPATCH_APP_ID
#   Secret:   BMT_DISPATCH_APP_PRIVATE_KEY (path to PEM file or inline PEM content)
#   The VM needs app ID + installation ID + private key per repo (prefix GITHUB_APP_TEST_
#   or GITHUB_APP_PROD_); those are typically in GCP Secret Manager, not GitHub secrets.
#   Private keys can be stored in .github/bmt/config/secrets/*.pem (gitignored).

# ── Required (client/CI) ───────────────────────────────────────────────────────

# GCS bucket name (no gs:// prefix)
GCS_BUCKET=train-kws-202311-bmt-gate

# Workload Identity Federation provider (projects/<n>/locations/global/workloadIdentityPools/...)
GCP_WIF_PROVIDER=projects/416686035248/locations/global/workloadIdentityPools/bmt-gate-gha-dev/providers/github-oidc

# Service account email used for WIF impersonation
GCP_SA_EMAIL=bmt-runner-sa@train-kws-202311.iam.gserviceaccount.com

# GCP project ID (for VM operations)
GCP_PROJECT=train-kws-202311

# VM zone (e.g. europe-west4-a)
GCP_ZONE=europe-west4-a

# VM instance name
BMT_VM_NAME=bmt-performance-gate

# ── Optional (client passes to VM or uses defaults) ────────────────────────────

# Project filter for the matrix command: "all" or a JSON array of project keys (e.g. ["sk"]).
# Default: all
BMT_PROJECTS=all

# Status context name: client embeds this in the run trigger; the VM uses it for
# commit status and Check Run. Set only to override default or match branch protection.
# Default: BMT Gate
BMT_STATUS_CONTEXT=BMT Gate

# Seconds to wait for the VM handshake acknowledgement before timing out.
# Default: 180
BMT_HANDSHAKE_TIMEOUT_SEC=180

# GitHub App ID used by Actions to dispatch bmt.yml.
BMT_DISPATCH_APP_ID=2922431

# GitHub App private key for dispatch token minting (PEM path or inline PEM content).
BMT_DISPATCH_APP_PRIVATE_KEY=".github/bmt/config/secrets/core-main-bmt.private-key.pem"
