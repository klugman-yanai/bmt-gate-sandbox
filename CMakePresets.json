{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "sk_gcc_Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/sk/gcc_Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "sk_gcc_Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/sk/gcc_Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ]
}
