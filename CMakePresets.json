{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "MOCK_gcc_Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/MOCK/gcc_Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "MOCK_gcc_Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/MOCK/gcc_Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "MOCK_xtensa_Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/MOCK/xtensa_Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "MOCK_gcc_Release-build",
      "configurePreset": "MOCK_gcc_Release"
    },
    {
      "name": "MOCK_gcc_Debug-build",
      "configurePreset": "MOCK_gcc_Debug"
    },
    {
      "name": "MOCK_xtensa_Release-build",
      "configurePreset": "MOCK_xtensa_Release"
    }
  ]
}
