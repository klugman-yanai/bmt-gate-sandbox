{
  "version": 1,
  "description": "Canonical configuration contract for workflows, VM bootstrap, and local tools.",
  "contexts": {
    "github_repo_vars": {
      "required": [
        "GCS_BUCKET",
        "GCP_WIF_PROVIDER",
        "GCP_SA_EMAIL",
        "GCP_PROJECT",
        "GCP_ZONE",
        "BMT_VM_NAME"
      ],
      "optional": [
        "BMT_PROJECTS",
        "BMT_STATUS_CONTEXT",
        "BMT_RUNTIME_CONTEXT",
        "BMT_RUNTIME_BACKEND",
        "BMT_CLOUD_RUN_JOB",
        "BMT_CLOUD_RUN_REGION",
        "BMT_HANDSHAKE_TIMEOUT_SEC",
        "BMT_PREEMPT_ON_PR_STALE_QUEUE",
        "BMT_TRIGGER_STALE_SEC",
        "BMT_TRIGGER_METADATA_KEEP_RECENT",
        "BMT_DISPATCH_APP_ID"
      ]
    },
    "vm_metadata": {
      "required": [
        "GCS_BUCKET"
      ],
      "optional": [
        "BMT_REPO_ROOT"
      ]
    },
    "vm_runtime_env": {
      "optional": [
        "GITHUB_APP_TEST_ID",
        "GITHUB_APP_TEST_INSTALLATION_ID",
        "GITHUB_APP_TEST_PRIVATE_KEY",
        "GITHUB_APP_PROD_ID",
        "GITHUB_APP_PROD_INSTALLATION_ID",
        "GITHUB_APP_PROD_PRIVATE_KEY",
        "GH_APP_TEST_ID",
        "GH_APP_TEST_INSTALLATION_ID",
        "GH_APP_TEST_PRIVATE_KEY",
        "GH_APP_PROD_ID",
        "GH_APP_PROD_INSTALLATION_ID",
        "GH_APP_PROD_PRIVATE_KEY"
      ]
    },
    "local_dev_env": {
      "optional": [
        "GCS_BUCKET",
        "GCP_PROJECT",
        "GCP_ZONE",
        "BMT_VM_NAME"
      ]
    }
  },
  "consistency_checks": {
    "repo_vs_vm_metadata": [
      "GCS_BUCKET"
    ],
    "repo_var_vs_branch_required_status_context": [
      {
        "repo_var": "BMT_STATUS_CONTEXT",
        "branch": "dev",
        "context_substring": "bmt"
      }
    ]
  },
  "defaults": {
    "BMT_PROJECTS": "all",
    "BMT_STATUS_CONTEXT": "BMT Gate",
    "BMT_RUNTIME_CONTEXT": "BMT Runtime",
    "BMT_RUNTIME_BACKEND": "vm",
    "BMT_HANDSHAKE_TIMEOUT_SEC": "180",
    "BMT_PREEMPT_ON_PR_STALE_QUEUE": "1",
    "BMT_TRIGGER_STALE_SEC": "900",
    "BMT_TRIGGER_METADATA_KEEP_RECENT": "2",
    "BMT_REPO_ROOT": "/opt/bmt"
  },
  "recommended_minimal_input": [
    "GCS_BUCKET",
    "GCP_WIF_PROVIDER",
    "GCP_SA_EMAIL",
    "GCP_PROJECT",
    "GCP_ZONE",
    "BMT_VM_NAME"
  ]
}
