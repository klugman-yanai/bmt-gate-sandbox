# BMT GitHub repository variables — copy to .env and fill in values.
# Prefer: run `just terraform-export-vars` first to set Terraform-sourced vars,
# then copy this to .env and fill in only the secrets (GCP_WIF_PROVIDER, BMT_DISPATCH_APP_*).
# Or fill all values and run: bash infra/bootstrap/bootstrap_gh_vars.sh --env-file infra/bootstrap/.env
#
# Secrets (set manually, not in Terraform):
#   GCP_WIF_PROVIDER, BMT_DISPATCH_APP_ID, BMT_DISPATCH_APP_PRIVATE_KEY
# Terraform exports: GCS_BUCKET, GCP_PROJECT, GCP_ZONE, BMT_VM_NAME, GCP_SA_EMAIL, BMT_PUBSUB_SUBSCRIPTION, etc.

# ── Required (or from Terraform export) ────────────────────────────────────────
GCS_BUCKET=
GCP_WIF_PROVIDER=
GCP_SA_EMAIL=
GCP_PROJECT=
GCP_ZONE=
BMT_VM_NAME=
BMT_PUBSUB_SUBSCRIPTION=

# ── Optional ───────────────────────────────────────────────────────────────────
BMT_PROJECTS=all
BMT_STATUS_CONTEXT=BMT Gate
BMT_RUNTIME_CONTEXT=BMT Runtime
BMT_HANDSHAKE_TIMEOUT_SEC=180
BMT_PREEMPT_ON_PR_STALE_QUEUE=1
BMT_TRIGGER_STALE_SEC=900
BMT_TRIGGER_METADATA_KEEP_RECENT=2
BMT_DISPATCH_APP_ID=

# GitHub App private key (path to PEM or inline)
BMT_DISPATCH_APP_PRIVATE_KEY=
