# BMT GitHub repository variables — copy to .env and fill in values.
# Prefer: run `just pulumi` first to set Pulumi-sourced vars, then copy this to
# .env and fill in the remaining manual values.
#
# Manual values:
#   GCP_WIF_PROVIDER
#   GitHub repo secrets: BMT_GITHUB_APP_ID, BMT_GITHUB_APP_INSTALLATION_ID, BMT_GITHUB_APP_PRIVATE_KEY
#   GitHub repo secrets: BMT_GITHUB_APP_DEV_ID, BMT_GITHUB_APP_DEV_INSTALLATION_ID, BMT_GITHUB_APP_DEV_PRIVATE_KEY
#   GCP Secret Manager secrets: GITHUB_APP_ID, GITHUB_APP_INSTALLATION_ID, GITHUB_APP_PRIVATE_KEY
#   GCP Secret Manager secrets: GITHUB_APP_DEV_ID, GITHUB_APP_DEV_INSTALLATION_ID, GITHUB_APP_DEV_PRIVATE_KEY
#   GCP Secret Manager secrets (Drive transfer; populate after `pulumi up`):
#     BMT_DRIVE_CLIENT_ID, BMT_DRIVE_CLIENT_SECRET  — OAuth2 Desktop app credentials
#     BMT_DRIVE_REFRESH_TOKEN                       — user refresh token (drive.readonly scope)
#     Obtain: gcloud auth application-default login --client-id-file=secrets/... --scopes=drive.readonly,cloud-platform
#     Then read refresh_token from ~/.config/gcloud/application_default_credentials.json
#
# GitHub reporting selects credentials from the repository slug:
#   Kardome-org/* -> GITHUB_APP_*
#   non-org repos -> GITHUB_APP_DEV_*

# Required repo vars
GCS_BUCKET=
GCP_WIF_PROVIDER=
GCP_SA_EMAIL=
GCP_PROJECT=
GCP_ZONE=
CLOUD_RUN_REGION=
BMT_CONTROL_JOB=
BMT_TASK_STANDARD_JOB=
BMT_TASK_HEAVY_JOB=
BMT_DATASET_TRANSFER_JOB=

# Optional repo vars
BMT_STATUS_CONTEXT=BMT Gate

# Primary org-owned GitHub App
BMT_GITHUB_APP_ID=
BMT_GITHUB_APP_INSTALLATION_ID=
BMT_GITHUB_APP_PRIVATE_KEY=

# Temporary dev GitHub App
BMT_GITHUB_APP_DEV_ID=
BMT_GITHUB_APP_DEV_INSTALLATION_ID=
BMT_GITHUB_APP_DEV_PRIVATE_KEY=
