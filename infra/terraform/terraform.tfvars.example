# Optional override file. Copy to terraform.tfvars to override defaults.
# When using `just terraform`, required values (gcp_project, gcp_zone, gcs_bucket, service_account)
# are read from GitHub repo variables; this file is only needed for overrides.
gcp_project  = "my-gcp-project"
gcp_zone     = "europe-west4-a"
gcs_bucket   = "my-bmt-bucket"
# bmt_vm_name = "bmt-gate-blue"   # optional; default is bmt-gate-blue (green is <base>-green)
service_account = "bmt-vm@my-gcp-project.iam.gserviceaccount.com"
# Use same path as bmt-vm-provision.yml (packaged entrypoint)
startup_wrapper_script_path = "../../.github/bmt/ci/resources/startup_entrypoint.sh"

# Optional (have defaults in variables.tf):
# image_family = "bmt-runtime"
# bmt_repo_root = "/opt/bmt"
