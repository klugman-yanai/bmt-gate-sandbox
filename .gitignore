**.zip
**.7z
**.tar.gz
**.tar

# Build/output junk
build/
data/
local_batch/
sk_runtime/
secrets/
debug/
.local/
cache/

# Python
**/__pycache__/
*.pyc
.venv/
*.egg-info/
.coverage
coverage.xml
junit.xml

# Release layout (generated by just release-package from .github/)
.github-release/

# Local staging (manual assets)
repo/staging/

# Generated logs/results
*.log
*.tmp
*.out
bmt_root_results.json

# VM/BMT runtime artifacts (bucket sync + handshake staging)
gcp/local/runtime/triggers/
gcp/local/runtime/**/inputs/**/*.wav
gcp/local/runtime/**/outputs/
gcp/local/runtime/**/results/

# WAV datasets — large runtime assets, not tracked in git.
# Upload to GCS with: just upload-data <project> <zip-or-folder>
# Pass --local to also mirror locally: just upload-data <project> <source> --local
*.wav
gcp/stage/**/inputs/**/*.wav

# Local audio dataset trees (e.g. audio/sk/false_rejects/)
audio/

# Windows alternate data stream markers (Zone.Identifier)
*:Zone.Identifier
*.Zone.Identifier

# FUSE mount points for read-only observation of GCS input data (opt-in, dev QoL).
# Mount with: just mount-data <project>  Unmount with: just umount-data <project>
gcp/mnt/

# Tooling/editor
compile_commands.json
.vscode/
!.vscode/settings.json
.idea/
.cursor/plans/
*.swp
*~

# System
.DS_Store
Thumbs.db

# Local credentials and env (copy infra/bootstrap/.env.example to infra/bootstrap/.env)
gcp-key.json
.env
.secrets

# Claude Code local settings (machine-specific paths)
.claude/settings.local.json
